extends ../../layouts/default.pug
block style 
    link(rel="stylesheet", href="/client/css/friend.css")
block main
    .main 
        h1 Lời mời kết bạn
        .friend 
            .inner-search
                form(action="" class="form-search")
                    input(type="text" name="keyword" class="input-search-user" id="input-search-user" placeholder="Tìm kiếm...")
                    button(type="submit") 
                        i(class="fa-solid fa-magnifying-glass") 

            .inner-users
                .row.align-items-stretch
                    each user in users 
                        .col-md-4
                            .box-user 
                                .inner-avatar 
                                    img(src=(user.gender == "male" ? "/client/images/male-default.png": "/client/images/female-default.png") alt="")
                                .inner-info 
                                    div(class="inner-name") #{user.fullName}
                                    div(class="inner-button accept" data-user-id=user.id) 
                                        button(class="accept-btn btn btn-sm btn-success") Đồng ý
                                        button(class="refuse-btn btn btn-sm btn-danger ms-2") Từ chối
                                        button(class="refused-btn btn btn-sm btn-secondary" disabled) Đã từ chối
                                        button(class="accepted-btn btn btn-sm btn-primary" disabled) Đã Đã chấp nhận
                                    
block script     
    script(src="/client/js/friend.js") 
            