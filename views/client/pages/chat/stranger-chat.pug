extends ../../layouts/default.pug

block style 
    //- Upload Images
    link(rel="stylesheet", href="https://unpkg.com/file-upload-with-preview/dist/style.css")
    //- ViewerJs
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.6/viewer.css")
    link(rel="stylesheet", href="/client/css/main.css")
block main
    .main
        div(room-id= room_id)
        .chat(my-id=user.id)
            .inner-head
                if(stranger)
                    .inner-avatar 
                        .border-image 
                            img(src= stranger.avatar)
                        span(class=(stranger.statusOnline == "online" ? "online" : ""))
                    .inner-name #{stranger.fullName}
            .inner-body

            .inner-foot
                .inner-preview-images 
                    div(class="custom-file-container" data-upload-id="upload-images")
                form(action="", class="inner-form d-flex align-items-center ")
                    span(class="form-btn me-2")
                        <i class="fa-solid fa-file"></i>
                    label(
                            class="form-btn me-2"
                            for="file-upload-with-preview-upload-images"
                            )
                        <i class="fa-solid fa-image"></i>
                    input(
                        type="text"
                        placeholder="Aa..."
                        name="content"
                    )
                    span(class="form-btn ms-2 button-icon")
                        <i class="fa-solid fa-face-smile"></i>
                    
                    button(class="form-btn mx-2")
                        <i class="fa-solid fa-paper-plane"></i>
    div(class="tooltip" role="tooltip")
        emoji-picker

block script 
    //- Emoji Icon
    script(type="module" src="https://cdn.jsdelivr.net/npm/emoji-picker-element@^1/index.js")
    //-Upload Images
    script(src="https://unpkg.com/file-upload-with-preview/dist/file-upload-with-preview.iife.js") 
    //- Viewer js
    script(src="https://cdnjs.cloudflare.com/ajax/libs/viewerjs/1.11.6/viewer.js") 
    script(type="module" src="/client/js/chat.js") 

                    